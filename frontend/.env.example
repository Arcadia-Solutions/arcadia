# The base URL for the API that the frontend will communicate with.
# No trailing slash
VITE_API_BASE_URL=http://127.0.0.1:8080

# The name of the site displayed in the frontend.
# You can customize this to reflect your application's branding.
VITE_SITE_NAME="Arcadia"

# If set to true, any unauthenticated user will be redirected to it
# What will be loaded is public/home/index.html
VITE_ENABLE_CUSTOM_FRONT_PAGE=false

# This is the label that will be displayed on the big input on /apply
VITE_APPLY_INPUT_MESSAGE="Why should we let you in"

# This message will be shown once the user sent their application
VITE_APPLICATION_SENT_MESSAGE="Application sent! You will hear back from us if you're selected."

############ Optional: kiwiirc settings ############
# URL where the Kiwi IRC webchat is served.
# /kiwiirc/ if proxied through the frontend nginx in Docker
# For local dev with the IRC client running on a different port, use e.g. http://localhost:8082/
VITE_IRC_WEBCHAT_URL=http://localhost:8082/
# WebSocket URL for the IRC server (Ergo).
# /webirc/websocket if proxied through the frontend nginx in Docker
# For local dev with Ergo exposed directly, use e.g. http://localhost:8097/
VITE_IRC_WEBSOCKET_URL=ws://localhost:8097/
############ Optional: kiwiirc settings ############
