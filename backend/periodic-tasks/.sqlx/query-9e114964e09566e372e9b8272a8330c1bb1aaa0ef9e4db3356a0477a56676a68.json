{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    rt.forum_thread_id,\n                    ft.name AS thread_name,\n                    rt.created_at\n                FROM artist_related_threads rt\n                JOIN forum_threads ft ON ft.id = rt.forum_thread_id\n                WHERE rt.artist_id = $1\n                ORDER BY rt.created_at DESC\n            ",
