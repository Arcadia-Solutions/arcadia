  "query": "\n                SELECT\n                    aa.title_group_id,\n                    a.id as artist_id,\n                    a.name as artist_name\n                FROM affiliated_artists aa\n                JOIN artists a ON a.id = aa.artist_id\n                WHERE aa.title_group_id = ANY($1)\n                ",
